{
  "version": 1,
  "sdk_version": "0.23.0",
  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://dxepvlxzlcbtzczpgyng.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "civicpulse-mcp",
      "version": "0.1.0",
      "title": "CivicPulse MCP"
    },
    "tools": [
      {
        "name": "list_my_reports",
        "title": "List my reports",
        "description": "List civic reports submitted by the signed-in user, newest first.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "description": "Max reports to return (default 20).",
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "get_report",
        "title": "Get report",
        "description": "Fetch a single civic report by its UUID. RLS applies — only the report owner, admins, or public columns are returned.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
              "description": "Report UUID."
            }
          },
          "required": [
            "id"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "create_report",
        "title": "Create civic report",
        "description": "Submit a new civic issue report (pothole, garbage, streetlight, other) at a given lat/lng on behalf of the signed-in user.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "title": {
              "type": "string",
              "minLength": 3,
              "maxLength": 200,
              "description": "Short issue title."
            },
            "description": {
              "description": "Optional detailed description.",
              "type": "string",
              "maxLength": 2000
            },
            "issue_type": {
              "type": "string",
              "enum": [
                "pothole",
                "garbage",
                "streetlight",
                "other"
              ],
              "description": "Issue category."
            },
            "latitude": {
              "type": "number",
              "minimum": -90,
              "maximum": 90
            },
            "longitude": {
              "type": "number",
              "minimum": -180,
              "maximum": 180
            },
            "severity": {
              "description": "Severity 1-5 (default 3).",
              "type": "integer",
              "minimum": 1,
              "maximum": 5
            }
          },
          "required": [
            "title",
            "issue_type",
            "latitude",
            "longitude"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_notifications",
        "title": "List my notifications",
        "description": "List in-app notifications for the signed-in user (status changes, admin updates). Supports pagination via `limit` and `offset`, or `cursor` (ISO timestamp of the last item's created_at) to fetch older pages.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "description": "Max notifications per page (default 20).",
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            },
            "offset": {
              "description": "Rows to skip from the start (default 0).",
              "type": "integer",
              "minimum": 0,
              "maximum": 10000
            },
            "cursor": {
              "description": "ISO timestamp; returns notifications older than this (use last item's created_at).",
              "type": "string",
              "format": "date-time",
              "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "list_unread_notifications",
        "title": "List unread notifications",
        "description": "List in-app notifications for the signed-in user that have not been marked as read. Supports pagination via `limit` and `offset`, or `cursor` (ISO timestamp of the last item's created_at) to fetch older pages.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "description": "Max notifications per page (default 20).",
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            },
            "offset": {
              "description": "Rows to skip from the start (default 0).",
              "type": "integer",
              "minimum": 0,
              "maximum": 10000
            },
            "cursor": {
              "description": "ISO timestamp; returns unread notifications older than this (use last item's created_at).",
              "type": "string",
              "format": "date-time",
              "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "mark_notification_read",
        "title": "Mark notification(s) as read",
        "description": "Mark one or more notifications as read for the signed-in user. Pass an array of notification IDs, or set all=true to mark every unread notification as read.",
        "annotations": {
          "readOnlyHint": false,
          "idempotentHint": true,
          "destructiveHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "ids": {
              "description": "Notification UUIDs to mark read.",
              "type": "array",
              "items": {
                "type": "string",
                "format": "uuid",
                "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
              }
            },
            "all": {
              "description": "If true, mark all unread notifications as read.",
              "type": "boolean"
            }
          }
        },
        "outputSchema": null
      }
    ]
  }
}
